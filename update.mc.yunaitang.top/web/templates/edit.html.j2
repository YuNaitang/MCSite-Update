{% extends "base.html.j2" %}
{% block title %}
    {% if is_new %}New Release{% else %}Edit Release {{ release.version }}{% endif %} - MC Launcher Update
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>{% if is_new %}New Release{% else %}Edit Release{% endif %}</h1>
    <a href="/admin/releases" class="btn btn-outline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to List
    </a>
</div>

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

<div class="form-container">
    {% if is_new %}
    <form method="POST" action="/admin/releases/new" class="release-form">
    {% else %}
    <form method="POST" action="/admin/releases/{{ release.id }}/edit" class="release-form">
    {% endif %}

        {# Version #}
        <div class="form-group required">
            <label for="f-version">Version</label>
            <input
                type="text" id="f-version" name="version"
                class="form-input" placeholder="1.3.0"
                value="{{ release.version if release else '' }}"
                required pattern="^\d+\.\d+\.\d+"
            />
            <span class="form-hint">Semver format: X.Y.Z (e.g. 1.0.0)</span>
        </div>

        <div class="form-row">
            {# Platform #}
            <div class="form-group">
                <label for="f-platform">Platform</label>
                <select id="f-platform" name="platform" class="form-select">
                    <option value="">All platforms</option>
                    {% for p in platforms %}
                    <option value="{{ p.value }}"
                        {% if release and release.platform == p.value %}selected{% endif %}>
                        {{ p.value }}
                    </option>
                    {% endfor %}
                </select>
                <span class="form-hint">Leave empty to match all platforms</span>
            </div>

            {# Architecture #}
            <div class="form-group">
                <label for="f-arch">Architecture</label>
                <select id="f-arch" name="arch" class="form-select">
                    <option value="">All architectures</option>
                    {% for a in archs %}
                    <option value="{{ a.value }}"
                        {% if release and release.arch == a.value %}selected{% endif %}>
                        {{ a.value }}
                    </option>
                    {% endfor %}
                </select>
                <span class="form-hint">Leave empty to match all architectures</span>
            </div>
        </div>

        <div class="form-row">
            {# OS version range #}
            <div class="form-group">
                <label for="f-os-min">Min OS Version</label>
                <input type="text" id="f-os-min" name="os_version_min"
                    class="form-input" placeholder="8.0"
                    value="{{ release.os_version_min if release and release.os_version_min else '' }}"
                />
                <span class="form-hint">Leave empty for no lower bound</span>
            </div>
            <div class="form-group">
                <label for="f-os-max">Max OS Version</label>
                <input type="text" id="f-os-max" name="os_version_max"
                    class="form-input" placeholder="14.99"
                    value="{{ release.os_version_max if release and release.os_version_max else '' }}"
                />
                <span class="form-hint">Leave empty for no upper bound</span>
            </div>
        </div>

        <div class="form-row">
            {# Channel #}
            <div class="form-group">
                <label for="f-channel">Channel</label>
                <input type="text" id="f-channel" name="channel"
                    class="form-input" placeholder="official"
                    value="{{ release.channel if release and release.channel else '' }}"
                />
                <span class="form-hint">Leave empty to match all channels</span>
            </div>

            {# Build number #}
            <div class="form-group">
                <label for="f-build-number">Build Number</label>
                <input type="number" id="f-build-number" name="build_number"
                    class="form-input" placeholder="105"
                    value="{{ release.build_number if release and release.build_number else '' }}"
                />
                <span class="form-hint">For reference only, not used in version comparison</span>
            </div>
        </div>

        {# Download URL #}
        <div class="form-group">
            <label for="f-download-url">Download URL</label>
            <input type="url" id="f-download-url" name="download_url"
                class="form-input" placeholder="https://example.com/download"
                value="{{ release.download_url if release and release.download_url else '' }}"
            />
            <span class="form-hint">Link to community download page (QQ group announcement, forum post, etc.)</span>
        </div>

        {# Changelog #}
        <div class="form-group">
            <label for="f-changelog">Changelog</label>
            <textarea id="f-changelog" name="changelog"
                class="form-textarea" rows="5"
                placeholder="## 1.3.0&#10;- New feature A&#10;- Fixed issue B">{{ release.changelog if release and release.changelog else '' }}</textarea>
            <span class="form-hint">Markdown supported</span>
        </div>

        <hr />

        {# Toggles #}
        <div class="form-row">
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" name="is_active" value="1"
                        {% if not release or release.is_active %}checked{% endif %}
                        class="toggle-checkbox"
                    />
                    <span class="toggle-switch"></span>
                    Active
                </label>
                <span class="form-hint">When inactive, app clients will not receive this update</span>
            </div>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" name="is_grayscale" value="1" id="grayscale-toggle"
                        {% if release and release.is_grayscale %}checked{% endif %}
                        class="toggle-checkbox"
                    />
                    <span class="toggle-switch"></span>
                    Grayscale Release
                </label>
            </div>
        </div>

        {# Grayscale percentage #}
        <div class="form-group" id="grayscale-pct-group" style="display: {% if release and release.is_grayscale %}block{% else %}none{% endif %};">
            <label for="f-grayscale-pct">Grayscale Percentage</label>
            <div class="range-group">
                <input type="range" id="f-grayscale-pct" name="grayscale_pct"
                    min="0" max="100"
                    value="{{ release.grayscale_pct if release and release.grayscale_pct else 20 }}"
                    class="range-input"
                />
                <span class="range-value" id="grayscale-pct-label">
                    {{ release.grayscale_pct if release and release.grayscale_pct else 20 }}%
                </span>
            </div>
            <span class="form-hint">Only XX% of users will receive this grayscale version</span>
        </div>

        {# Submit #}
        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                {% if is_new %}Create Release{% else %}Save Changes{% endif %}
            </button>
            <a href="/admin/releases" class="btn btn-outline btn-lg">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script src="/admin/static/app.js"></script>
{% endblock %}
